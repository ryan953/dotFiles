{
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotFiles/templates/.claude/notify.sh 'Claude Code' 'Permission Required'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotFiles/templates/.claude/notify.sh 'Claude Code' 'Claude is waiting'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotFiles/templates/.claude/notify.sh 'Claude Code' 'Permission Requested'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotFiles/templates/.claude/notify.sh 'Claude Code' 'Execution Stopped'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "linear@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "sentry-skills@sentry-skills": true,
    "sentry@claude-plugins-official": true,
    "slack@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true
  }
}
